# Backend configuration (server/.env)
# Copy this file to .env and fill in the values

PORT=3002
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# Development: include localhost ports used by the frontend
# Production: only include your real domain(s)
CORS_WHITELIST=http://localhost:3005,https://licentia.tu-dominio.com

# JWT — MUST be a strong random secret in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production

# Rate limiting (defaults: 100 requests per 15 minutes per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
